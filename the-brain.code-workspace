{
  "folders": [
    {
      "name": "🧠 The Brain",
      "path": "."
    }
  ],
  "settings": {
    "files.exclude": {
      "**/.git": true,
      "**/node_modules": true
    },
    "editor.formatOnSave": true,
    "search.exclude": {
      "**/node_modules": true
    }
  },
  "extensions": {
    "recommendations": [
      "yzhang.markdown-all-in-one",
      "bierner.markdown-preview-github-styles",
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "AI: Init Memory for This Project",
        "type": "shell",
        "command": "claude",
        "args": ["--print", "/init-memory"],
        "options": { "cwd": "${workspaceFolder}" },
        "presentation": { "reveal": "always", "panel": "new", "focus": true },
        "problemMatcher": []
      },
      {
        "label": "AI: With Codex (collaborative task)",
        "type": "shell",
        "command": "claude",
        "args": ["/with-codex ${input:codexTask}"],
        "options": { "cwd": "${workspaceFolder}" },
        "presentation": { "reveal": "always", "panel": "new", "focus": true },
        "problemMatcher": []
      }
    ],
    "inputs": [
      {
        "id": "codexTask",
        "type": "promptString",
        "description": "Describe the task for Claude + Codex to split and tackle together"
      }
    ]
  }
}
