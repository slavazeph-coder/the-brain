# BrainSNN Configuration
# Copy to .env and fill in values as needed.

# ── TRIBE v2 Server ──
# Python FastAPI server for real fMRI-based brain predictions
VITE_TRIBE_API=http://localhost:8642

# ── Google DeepMind Gemma 4 ──
# For deep AI-powered content analysis beyond regex pattern matching.
# Supports Google AI Studio or any OpenAI-compatible endpoint (Ollama, vLLM).
#
# Google AI Studio:
#   VITE_GEMMA_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemma-4-31b-it:generateContent
#   VITE_GEMMA_API_KEY=your-google-ai-studio-key
#
# Ollama (local):
#   VITE_GEMMA_API_ENDPOINT=http://localhost:11434/v1/chat/completions
#   VITE_GEMMA_API_KEY=
#
VITE_GEMMA_API_ENDPOINT=
VITE_GEMMA_API_KEY=

# ── Live Sync (WebSocket) ──
# Multi-user real-time brain state synchronization.
# Point to a WebSocket relay server.
#   VITE_SYNC_WS_URL=ws://localhost:8080
#
VITE_SYNC_WS_URL=
