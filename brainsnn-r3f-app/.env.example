# BrainSNN Configuration
# Copy to .env and fill in values as needed.
#
# ALL VARIABLES ARE OPTIONAL.
# Without any of these set, BrainSNN runs in pure-frontend simulation mode:
# • TRIBE v2 mode falls back to STDP simulation (no real fMRI predictions)
# • Gemma 4 deep analysis falls back to regex-based Cognitive Firewall scoring
# • Live Sync (multi-user) is disabled
# Set them when you want to upgrade specific layers to real backends.

# ── TRIBE v2 Server ──
# Python FastAPI server for real fMRI-based brain predictions
VITE_TRIBE_API=http://localhost:8642

# ── Google DeepMind Gemma 4 ──
# For deep AI-powered content analysis beyond regex pattern matching.
# Supports Google AI Studio or any OpenAI-compatible endpoint (Ollama, vLLM).
#
# Google AI Studio:
#   VITE_GEMMA_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemma-4-31b-it:generateContent
#   VITE_GEMMA_API_KEY=your-google-ai-studio-key
#
# Ollama (local):
#   VITE_GEMMA_API_ENDPOINT=http://localhost:11434/v1/chat/completions
#   VITE_GEMMA_API_KEY=
#
VITE_GEMMA_API_ENDPOINT=
VITE_GEMMA_API_KEY=

# ── Google Gemini (TechEx hackathon — Best Gemini track) ──
# Real Gemini API via Google AI Studio. Powers GeminiAnalysisPanel,
# multimodal captions in Layer 33 Multimodal RAG, and Counter-Draft rewrites.
#
# Get a key at https://aistudio.google.com/app/apikey
#   VITE_GEMINI_API_KEY=your-google-ai-studio-key
#   VITE_GEMINI_MODEL=gemini-2.5-flash       # or gemini-2.5-pro
#   VITE_GEMINI_API_BASE=                    # optional override
#
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_API_BASE=

# ── Veea Lobster Trap (TechEx hackathon — Best Veea track) ──
# Optional remote endpoint. Lobster Trap also runs fully in-browser with
# local heuristics (prompt injection, secret leakage, PII redaction,
# destructive MCP tool gating) when these are unset.
#
#   VITE_LOBSTER_TRAP_URL=https://your-veea-lobster-trap.example/inspect
#   VITE_LOBSTER_TRAP_KEY=your-veea-issued-key
#
VITE_LOBSTER_TRAP_URL=
VITE_LOBSTER_TRAP_KEY=

# ── Live Sync (WebSocket) ──
# Multi-user real-time brain state synchronization.
# Point to a WebSocket relay server.
#   VITE_SYNC_WS_URL=ws://localhost:8080
#
VITE_SYNC_WS_URL=
